# ErrorDocument configurations for maintenance mode
ErrorDocument 403 /maintenance.html
ErrorDocument 404 /maintenance.html
ErrorDocument 500 /maintenance.html
ErrorDocument 502 /maintenance.html
ErrorDocument 503 /maintenance.html
ErrorDocument 504 /maintenance.html

# Redirect all traffic to maintenance.html during deployment
# Uncomment the following lines when deploying
# RewriteEngine On
# RewriteCond %{REQUEST_URI} !/maintenance.html$
# RewriteRule ^(.*)$ /maintenance.html [R=302,L]